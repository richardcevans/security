# Oracle AI Database 26ai on ADB-S connection.
# Use placeholders only. Do not commit a real .env file.

ADB_USERNAME=DEEPSEC_ADMIN
ADB_PASSWORD=replace-with-database-password

# Use an ADB wallet TNS alias such as yourdb_high, or a TCPS connect descriptor
# with placeholder host, port, and service_name values.
ADB_DSN=replace-with-adb-tns-alias-or-connect-descriptor

# Directory containing the unzipped wallet files, including tnsnames.ora and ewallet.pem.
ADB_WALLET_LOCATION=/path/to/unzipped/adb-wallet

# Wallet password created when the wallet was downloaded.
# This is not the database user password.
ADB_WALLET_PASSPHRASE=replace-with-wallet-password

# Optional aliases supported by the helper if your environment already uses DB_* names.
# DB_USER=DEEPSEC_ADMIN
# DB_PASSWORD=replace-with-database-password
# DB_DSN=replace-with-adb-tns-alias-or-connect-descriptor
# DB_WALLET_DIR=/path/to/unzipped/adb-wallet
# DB_WALLET_PASSWORD=replace-with-wallet-password

# Deep Sec context mode is environment-sensitive and must match your verified setup.
# Supported by this demo package:
# - direct_logon
# - external_token
# - local_tuple
DEEPSEC_CONTEXT_MODE=direct_logon

# Required only for service-user context modes such as external_token/local_tuple.
# direct_logon connects as local Deep Sec end users and does not use this token.
DEEPSEC_DATABASE_ACCESS_TOKEN=

# Linda identity values for the selected context mode.
# In local_tuple mode, DEEPSEC_LINDA_IDENTITY defaults to linda if omitted.
# In direct_logon mode, DEEPSEC_LINDA_KEY is the direct-logon password.
DEEPSEC_LINDA_IDENTITY=replace-with-verified-linda-identity
DEEPSEC_LINDA_KEY=replace-if-local-tuple-mode-requires-key

# Wendy identity values for the selected context mode.
# In local_tuple mode, DEEPSEC_WENDY_IDENTITY defaults to wendy if omitted.
# In direct_logon mode, DEEPSEC_WENDY_KEY is the direct-logon password.
DEEPSEC_WENDY_IDENTITY=replace-with-verified-wendy-identity
DEEPSEC_WENDY_KEY=replace-if-local-tuple-mode-requires-key

# In direct_logon mode, queries run as "linda" or "wendy" and qualify protected
# tables through this owner.
DEAL_OBJECT_OWNER=DEEPSEC_ADMIN

# Core demo vector settings.
# The runnable scripts use VECTOR(3, FLOAT32) and a single cosine-distance path.
DEAL_VECTOR_DIM=3
DEAL_VECTOR_METRIC=COSINE

# OCI Generative AI settings for 11_oci_genai_chatbot.py.
# The script uses your standard OCI SDK config file/profile.
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_GENAI_COMPARTMENT_ID=ocid1.compartment.oc1..replace-with-compartment-ocid
OCI_GENAI_MODEL_ID=ocid1.generativeaimodel.oc1.us-chicago-1.replace-with-model-ocid
