WEB_HR_HOST=127.0.0.1
WEB_HR_PORT=8012
# Optional HTTPS/HTTP redirect split. If WEB_HR_TLS_CERT and WEB_HR_TLS_KEY
# are set, WEB_HR_HTTPS_PORT controls the HTTPS app port. WEB_HR_PORT can then
# stay as the HTTP redirect port, or use WEB_HR_HTTP_REDIRECT_PORT explicitly.
WEB_HR_HTTPS_PORT=
WEB_HR_HTTP_REDIRECT_PORT=
WEB_HR_PUBLIC_HOST=
# Leave WEB_HR_DB_MODE blank for the local default.
# After .end-user-web-hr-app.env or .web-hr-app.env exists, ./run.sh defaults to oracledb.
# Set WEB_HR_DB_MODE=mock only for a simulated UI demo.
WEB_HR_DB_MODE=
PDB_NAME=FREEPDB1
# Defaults to WEB_HR_TNS_ALIAS, then PDB_NAME, then FREEPDB1.
WEB_HR_TNS_ALIAS=

# Passwords for the local Oracle Database accounts.
# Defaults to Oracle123 when these are unset.
WEB_HR_EMMA_PASSWORD=
WEB_HR_MARVIN_PASSWORD=
WEB_HR_END_USER_PASSWORD=

# Optional account for the audit panel only. Defaults to deepsec_admin/Oracle123.
WEB_HR_ADMIN_USER=deepsec_admin
WEB_HR_ADMIN_PASSWORD=Oracle123

# Optional python-oracledb settings
TNS_ADMIN=
WEB_HR_CONFIG_DIR=
WEB_HR_WALLET_LOCATION=
WEB_HR_WALLET_PASSWORD=
