FIND_MONEY_HOST=127.0.0.1
FIND_MONEY_PORT=8013
# Leave FIND_MONEY_DB_MODE blank for the lab default.
# After .find-the-money.env exists, ./run.sh defaults to oracledb.
# Set FIND_MONEY_DB_MODE=mock only for a simulated UI demo.
FIND_MONEY_DB_MODE=
FIND_MONEY_TNS_ALIAS=hrdb
FIND_MONEY_APP_DB_USER=web_hr_app_user
FIND_MONEY_APPLICATION_IDENTITY=web_hr_app

# Created by 00_setup_entra_web_app.sh
FIND_MONEY_APP_NAME=
FIND_MONEY_APP_CLIENT_ID=
FIND_MONEY_APP_CLIENT_SECRET=
FIND_MONEY_REDIRECT_URI=http://localhost:8013/callback
FIND_MONEY_USER_SCOPE=
FIND_MONEY_DB_SCOPE=
FIND_MONEY_APP_DB_SCOPE=
FIND_MONEY_TOKEN_URI=
FIND_MONEY_AUTH_URI=

# Optional demo persona UPNs written by 05_setup_entra_demo_users.sh.
ALEX_UPN=
PRIYA_UPN=
MARCUS_UPN=
NORA_UPN=

# Optional OCI Generative AI OpenAI-compatible chat API.
# The default base URL targets the Oracle Chicago region.
FIND_MONEY_OCI_GENAI_BASE_URL=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1
FIND_MONEY_OCI_GENAI_MODEL=cohere.command-r-plus-08-2024
FIND_MONEY_OCI_COMPARTMENT_ID=
FIND_MONEY_OCI_GENAI_API_KEY=
# Keep this key only in .find-the-money.env on the VM. Do not commit real keys.

# Keep DML disabled unless this is a disposable lab database.
FIND_MONEY_ALLOW_DML=0

# Optional python-oracledb settings
TNS_ADMIN=
FIND_MONEY_CONFIG_DIR=/opt/oracle/product/26ai/dbhome_1/network/admin
FIND_MONEY_WALLET_LOCATION=
FIND_MONEY_WALLET_PASSWORD=
