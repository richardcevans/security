GRANT_VIEW_HOST=127.0.0.1
GRANT_VIEW_PORT=8008
GRANT_VIEW_DB_MODE=mock
GRANT_VIEW_AUTH_MODE=demo

# Use the existing entra-id-data-grants lab network/auth setup.
# This mode runs: sqlplus -s /@hrdb
# The hrdb alias should contain TOKEN_AUTH=AZURE_INTERACTIVE.
# GRANT_VIEW_DB_MODE=sqlplus
GRANT_VIEW_TNS_ALIAS=hrdb
SQLPLUS_BIN=sqlplus
SQLPLUS_TIMEOUT_SECONDS=180

# True web-app mode:
#   GRANT_VIEW_AUTH_MODE=entra
#   GRANT_VIEW_DB_MODE=python
# The frontend uses MSAL to request an access token for the database app scope,
# then python-oracledb passes that token to Oracle.
GRANT_VIEW_ENTRA_SCOPE=

# Oracle mode placeholders. Fill these when wiring the real driver.
ORACLE_DSN=hrdb
TNS_ADMIN=C:\oracle\tns_admin
ORACLE_WALLET_LOCATION=C:\oracle\tns_admin\wallets\hrdb-dbsec-lab-FREEPDB1
ORACLE_CLIENT_LIB_DIR=
ORACLEDB_EXTERNAL_AUTH=true

# Expected token values for real validation.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
