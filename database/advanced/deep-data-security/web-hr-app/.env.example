WEB_HR_HOST=127.0.0.1
WEB_HR_PORT=8012
# Leave WEB_HR_DB_MODE blank for the lab default.
# After .web-hr-app.env exists, ./run.sh defaults to oracledb.
# Set WEB_HR_DB_MODE=mock only for a simulated UI demo.
WEB_HR_DB_MODE=
WEB_HR_TNS_ALIAS=hrdb

# Created by 00_setup_entra_web_app.sh
WEB_HR_APP_NAME=
WEB_HR_APP_CLIENT_ID=
WEB_HR_APP_CLIENT_SECRET=
WEB_HR_REDIRECT_URI=http://localhost:8012/callback
WEB_HR_USER_SCOPE=
WEB_HR_DB_SCOPE=
WEB_HR_APP_DB_SCOPE=
WEB_HR_TOKEN_URI=
WEB_HR_AUTH_URI=

# Optional python-oracledb settings
TNS_ADMIN=
